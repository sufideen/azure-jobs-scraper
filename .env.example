# Azure Jobs Scraper — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file — it is in .gitignore.

# Gmail account address (sender)
GMAIL_USER=your.gmail.address@gmail.com

# Gmail App Password (16 characters, NOT your Gmail login password)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email recipient — jobs report will be sent here
RECIPIENT_EMAIL=you@example.com
